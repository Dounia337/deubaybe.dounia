# Copy this file to .env and fill in real values before running the app.

# Postgres connection string (provision via Vercel's Postgres/Neon storage
# integration, or any hosted Postgres provider). Required — the app has no
# local-file database fallback.
DATABASE_URL=postgres://user:password@host/database

# Vercel Blob read/write token, used for admin image uploads.
# Set automatically in Vercel deployments once a Blob store is connected to
# the project; for local dev, get it via `vercel env pull` or the dashboard.
BLOB_READ_WRITE_TOKEN=

# Secret used to sign admin session JWTs. Generate a long random string, e.g.:
#   openssl rand -base64 48
JWT_SECRET=replace-this-with-a-long-random-string

# Credentials for the admin account created by `npm run seed`.
# Change the password after your first login from the admin panel is not
# built in yet — for now, re-run the seed with new values on a fresh DB,
# or update the admin_users table directly.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=Dounia

# Optional: email notifications for new contact form messages.
# Leave these unset to skip email entirely — messages are always saved
# to the database and visible in the admin panel regardless.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=portfolio@example.com
# NOTIFY_EMAIL=you@example.com
